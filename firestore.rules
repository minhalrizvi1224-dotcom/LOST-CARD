rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ── Users ──────────────────────────────────────────────────────────
    // Privileged fields only the admin (Admin SDK / admin panel) may change.
    // A user updating their OWN doc cannot touch these — blocks self-promotion
    // to admin, self-granting premium, clearing suspensions/warnings, etc.
    function safeUserUpdate() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'isAdmin','suspended','hbPlan','planExpiry','upgradePlan',
        'upgradedAt','upgradeApprovedBy','warningCount','warnings','geminiKey'
      ]);
    }
    // hbCount (free-message counter) may only go UP for a self-update — stops
    // a user resetting it to 0 in the console to get unlimited free messages.
    function hbCountNotReset() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['hbCount'])
        || request.resource.data.hbCount >= resource.data.hbCount;
    }
    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid)
                    && request.resource.data.get('isAdmin', false) == false
                    && request.resource.data.get('hbPlan', '') != 'upgraded';
      allow update: if isAdmin() || (isOwner(uid) && safeUserUpdate() && hbCountNotReset());

      // Admin messages — admin writes, owner reads + marks read
      match /adminMessages/{msgId} {
        allow read:   if isOwner(uid);
        allow update: if isOwner(uid);       // mark as read
        allow create: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    // ── Sessions ───────────────────────────────────────────────────────
    match /sessions/{id} {
      // Must stamp your own uid — can't write sessions under someone else's id
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow read:   if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── Complaints ─────────────────────────────────────────────────────
    match /complaints/{id} {
      allow create: if request.auth != null;
      allow read, update: if isAdmin();
    }

    // ── Admin settings (pool keys, payment config) ─────────────────────
    match /adminSettings/{doc} {
      allow read, write: if isAdmin();
    }

    // ── Lockouts — CF reads/writes via Admin SDK (bypasses rules), no client access
    match /lockouts/{id} {
      allow read:  if false;
      allow write: if false;
    }

    // ── Public HB config — Gemini keys for Hair Band, readable by all auth users
    // Admin writes here when saving Gemini pool keys. Keys are rate-limited so
    // exposure risk is low; without this regular users can't use Hair Band.
    match /publicConfig/{doc} {
      allow read:  if request.auth != null;
      allow write: if isAdmin();
    }

    // ── Sent messages log ───────────────────────────────────────────────
    match /sentMessages/{id} {
      allow read, write: if isAdmin();
    }

    // ── Hair Band AI query logs ─────────────────────────────────────────
    match /hbQueries/{id} {
      allow create: if request.auth != null;
      allow read:   if isAdmin() || (request.auth != null && resource.data.uid == request.auth.uid);
    }

    // ── Hair Band query logs (admin AI Queries tab reads these) ──────────
    match /hairBandLogs/{id} {
      allow create: if request.auth != null;
      allow read, write, delete: if isAdmin();
    }
  }
}
